# Copy this file to `.env` and adjust if you want a real provider.
#
#   cp .env.example .env
#
# The default needs NO key — the whole learning arc (build a dataset, validate it,
# run a SIMULATED fine-tune, and prove it beat the baseline) runs offline on the
# mock provider. NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
# Which provider should the repo use?
#
#   mock   -> deterministic, offline, in-process model + SIMULATED fine-tuning.
#             No key, no network, no cost. THE DEFAULT — and the only stack where
#             the entire fine-tune lifecycle is free.
#   openai -> real OpenAI chat + fine-tuning. Running a fine-tune job COSTS REAL
#             MONEY and is opt-in (the tune scripts require an explicit --real
#             flag and a confirmation). Needs OPENAI_API_KEY.
#   claude -> Claude chat only. Anthropic fine-tuning is a limited/enterprise
#             program, not self-serve, so the tuning lifecycle is unavailable on
#             this stack. Still usable as a base/teacher model. Needs ANTHROPIC_API_KEY.
# ---------------------------------------------------------------------------
PROVIDER=mock

# After a REAL OpenAI fine-tune (examples/04 --real), paste the resulting model id
# here so examples 05-06 can use it without re-tuning. Ignored on PROVIDER=mock.
FT_MODEL=

# --- API keys (optional) are NOT stored here ---
# The default mock needs no key. To use a real provider, store its key in your OS
# keychain and inject it per-command with `secrun` (setup: ../SECRETS.md), then run
# key-using scripts as:  secrun python examples/...
#   PROVIDER=openai  needs  OPENAI_API_KEY     https://platform.openai.com/api-keys
#   PROVIDER=claude  needs  ANTHROPIC_API_KEY  https://console.anthropic.com/settings/keys
